<Window x:Class="Tabify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tabify" Height="600" Width="800"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="WindowBorder" Background="#1e1e1e" BorderBrush="#3d3d3d" BorderThickness="1">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowTop" Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="RowBottom" Height="0"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColLeft" Width="0"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ColRight" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- アタッチウィンドウ配置エリア（常に中央） -->
            <Border x:Name="ContentArea" Grid.Row="1" Grid.Column="1" Background="#1e1e1e" Margin="4,0,4,4">
                <TextBlock x:Name="DropHintTextCenter"
                           Text="ここにウィンドウをドロップして追加"
                           Foreground="DimGray" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Border>

            <!-- 共通タイトルバー（上部固定・ドラッグ可能・キャプションボタンあり） -->
            <Border x:Name="TitleBarBg" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="#2d2d30" MouseLeftButtonDown="TabBarBg_MouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <!-- ヒントテキスト -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" x:Name="HintPanel">
                        <TextBlock x:Name="DropHintText" 
                                   Text="ここにウィンドウをドロップして追加"
                                   Foreground="Gray" FontSize="11"
                                   Margin="15,0,0,0" IsHitTestVisible="False"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- カスタムキャプションボタン（右端） / [要件7] 新規ボタン追加 -->
                    <StackPanel x:Name="CaptionButtons" DockPanel.Dock="Right"
                                Orientation="Horizontal" VerticalAlignment="Stretch">
                        
                        <!-- [要件7] すべてのウィンドウを集約するアイコン -->
                        <Border x:Name="BtnAttachAll" Width="40" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="CaptionBtn_Down"
                                MouseLeftButtonUp="BtnAttachAll_Click"
                                MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave"
                                ToolTip="表示中のすべてのウィンドウを集約する">
                            <TextBlock Text="⇲" FontSize="14" Foreground="#cccccc"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- [要件7] 設定アイコン -->
                        <Border x:Name="BtnSettings" Width="40" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="CaptionBtn_Down"
                                MouseLeftButtonUp="BtnSettings_Click"
                                MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave"
                                ToolTip="表示設定">
                            <TextBlock Text="⚙" FontSize="14" Foreground="#cccccc"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <Border x:Name="BtnMinimize" Width="46" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="CaptionBtn_Down"
                                MouseLeftButtonUp="BtnMinimize_Click"
                                MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave">
                            <TextBlock Text="&#x2014;" FontSize="11" Foreground="#cccccc"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="BtnMaximize" Width="46" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="CaptionBtn_Down"
                                MouseLeftButtonUp="BtnMaximize_Click"
                                MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave">
                            <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="11" Foreground="#cccccc"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="BtnClose" Width="46" Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="CaptionBtn_Down"
                                MouseLeftButtonUp="BtnClose_Click"
                                MouseEnter="CloseBtn_Enter" MouseLeave="CaptionBtn_Leave">
                            <TextBlock Text="&#x2715;" FontSize="11" Foreground="#cccccc"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 動的配置されるタブバーコンテナ -->
            <Border x:Name="TabBarContainer" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="{x:Null}" Margin="0,0,180,0" MouseLeftButtonDown="TabBarBg_MouseLeftButtonDown">
                <Grid>
                    <Border x:Name="DropHighlight" Background="#2a579a" Opacity="0" IsHitTestVisible="False"/>

                    <!-- タブスクロール ◀ ボタン（タブ溢れ時のみ表示） -->
                    <Border x:Name="TabScrollLeft" Grid.Row="0"
                            Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                            Background="#2d2d30" Visibility="Collapsed" Cursor="Hand"
                            MouseLeftButtonUp="TabScrollLeft_Click"
                            MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave"
                            Margin="0">
                        <TextBlock x:Name="TabScrollLeftIcon" Text="◀" FontSize="10" Foreground="#cccccc"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- タブスクロール ▶ ボタン（タブ溢れ時のみ表示） -->
                    <Border x:Name="TabScrollRight" Grid.Row="0"
                            Width="28" Height="28" VerticalAlignment="Stretch"
                            Background="#2d2d30" Visibility="Collapsed" Cursor="Hand"
                            MouseLeftButtonUp="TabScrollRight_Click"
                            MouseEnter="CaptionBtn_Enter" MouseLeave="CaptionBtn_Leave"
                            HorizontalAlignment="Left" Margin="28,0,0,0">
                        <TextBlock x:Name="TabScrollRightIcon" Text="▶" FontSize="10" Foreground="#cccccc"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- タブヘッダー Canvas -->
                    <Canvas x:Name="TabBar" Grid.Row="0" Background="{x:Null}"
                            ClipToBounds="True"
                            MouseMove="TabBar_MouseMove"
                            MouseLeftButtonUp="TabBar_MouseLeftButtonUp"
                            MouseWheel="TabBar_MouseWheel"
                            SizeChanged="TabBar_SizeChanged"
                            IsHitTestVisible="True"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
